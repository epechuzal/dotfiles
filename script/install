#!/usr/bin/env bash
#
# Run all dotfiles installers.

set -e

cd "$(dirname $0)"/..

# Ordered installers — each depends on the one before it:
#   homebrew → zsh (shell theme) → node (nvm/npm) → claude (needs node + npm)
ORDERED=(
  ./homebrew/install.sh
  ./zsh/install.sh
  ./node/install.sh
  ./claude/install.sh
)

for installer in "${ORDERED[@]}"; do
  echo "» $installer"
  sh -c "$installer"
done

# Run remaining installers (order doesn't matter)
for installer in $(find . -name install.sh | sort); do
  skip=false
  for ordered in "${ORDERED[@]}"; do
    [ "$installer" = "$ordered" ] && skip=true
  done
  $skip && continue
  echo "» $installer"
  sh -c "$installer"
done
